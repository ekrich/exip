#!/usr/bin/env bash
#
# Run examples: use -help to see options
# Run from exip directory: scripts/run-examples
#

# Use -euxo for debug
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
EXAMPLES_DIR="${PROJECT_ROOT}/bin/examples"
UTILS_DIR="${PROJECT_ROOT}/bin/utils"

if [ -z "$(ls -A "$EXAMPLES_DIR" 2>/dev/null)" ] || [ -z "$(ls -A "$UTILS_DIR" 2>/dev/null)" ]; then
    echo "Error: Build directories are empty. Please run build first." >&2
    exit 1
fi

echo "Running examples..."
cd ${EXAMPLES_DIR}

echo
echo "exipg (grammar generation)"
echo

echo "[1] exipg text output for EXIOptions schema"
cd ${UTILS_DIR}
./exipg -text -ops=0001000 -schema=EXIOptions-xsd.exi
cd ${EXAMPLES_DIR}

echo
echo "exipe (encode)"
echo

echo "[2] exipe schema-informed example"
./exipe -schema=exipe-test-xsd.exi,exipe-test-types-xsd.exi,exipe-test-nested-xsd.exi exipe-test-schema.exi

echo "[3] exipe schemaless example"
./exipe exipe-test.exi

echo
echo "exipd (decode)"
echo

echo "[4] exipd schema example (XML output)"
./exipd -xml -schema=exipd-test-xsd.exi exipd-test.exi

echo "[5] exipd schema example (EXI output)"
./exipd -exi -schema=exipd-test-xsd.exi exipd-test.exi

echo "[6] exipd schema example (XML output)"
./exipd -xml -schema=exipd-test-schema-xsd.exi exipd-test-schema.exi

echo "[7] exipd schema example (EXI output)"
./exipd -exi -schema=exipd-test-schema-xsd.exi exipd-test-schema.exi

echo "[8] exipd XML Schema document"
./exipd -xml -schema=XMLSchema-xsd.exi,xml-xsd.exi XMLSchema-schema-xsd.exi

echo "[9] exipd schemaless example"
./exipd -xml exipd-test.exi

echo "[10] exipd with exipe-test (schema-informed roundtrip)"
./exipd -xml -schema=exipe-test-xsd.exi,exipe-test-nested-xsd.exi,exipe-test-types-xsd.exi exipe-test-schema.exi

echo "[11] exipd with exipe-test (schemaless roundtrip)"
./exipd -xml exipe-test.exi

# Check if .exi files changed (only if git available and files tracked)
if command -v git >/dev/null 2>&1; then
    if git ls-files --error-unmatch exipe-test-schema.exi >/dev/null 2>&1; then
        if ! git diff --quiet exipe-test-schema.exi; then
            echo "WARNING: exipe-test-schema.exi changed after encoding"
            exit 1
        fi
    fi
    if git ls-files --error-unmatch exipe-test.exi >/dev/null 2>&1; then
        if ! git diff --quiet exipe-test.exi; then
            echo "WARNING: exipe-test.exi changed after encoding"
            exit 1
        fi
    fi
fi

echo
echo "Done."
